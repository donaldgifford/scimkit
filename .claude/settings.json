      "Bash(go run *)",
      "Bash(golangci-lint *)",
      "Bash(make lint-md *)",
      "Bash(make test *)",
      "Bash(gh api *)",
      "Bash(gh release *)",
      "Bash(git fetch *)",
      "Bash(gh label *)",
      "Bash(go list *)",
      "Bash(go get *)",
      "Bash(go mod *)",
      "Bash(docz --help)",
      "Bash(docz create *)",
      "Bash(docz template *)",
      "Bash(docz list *)",
      "Bash(just --list)",
      "Bash(docz update *)",
